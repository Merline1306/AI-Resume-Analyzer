# ==========================================================
# AI Resume Analyzer
# .gitignore
# ==========================================================

# ----------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------
.env

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------
venv/
.venv/
env/
ENV/

# ----------------------------------------------------------
# Jupyter Notebook
# ----------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------
# VS Code
# ----------------------------------------------------------
.vscode/

# ----------------------------------------------------------
# PyCharm
# ----------------------------------------------------------
.idea/

# ----------------------------------------------------------
# macOS
# ----------------------------------------------------------
.DS_Store

# ----------------------------------------------------------
# Windows
# ----------------------------------------------------------
Thumbs.db
desktop.ini

# ----------------------------------------------------------
# SQLite Database
# ----------------------------------------------------------
database/*.db
*.sqlite3

# ----------------------------------------------------------
# Generated Reports
# ----------------------------------------------------------
reports/*.pdf
reports/*.docx
reports/*.html

# ----------------------------------------------------------
# Uploaded Files
# ----------------------------------------------------------
uploads/
temp/
tmp/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------
# Build Files
# ----------------------------------------------------------
build/
dist/
*.egg-info/

# ----------------------------------------------------------
# Streamlit Cache
# ----------------------------------------------------------
.streamlit/cache/

# ----------------------------------------------------------
# Model Cache
# ----------------------------------------------------------
.cache/
models/

# ----------------------------------------------------------
# Python Testing
# ----------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.bak
*.tmp
*.swp